{
  "name": "jit-google-workspace-solution",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --workspaces",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vite": "^6.0.11"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "vite": {
      "esbuild": "0.28.1"
    },
    "gaxios": {
      "uuid": "^11.1.1"
    },
    "googleapis-common": {
      "uuid": "^11.1.1"
    },
    "teeny-request": {
      "uuid": "^11.1.1"
    },
    "google-gax": {
      "uuid": "^11.1.1"
    }
  }
}
